# ─── .streamlit/secrets.toml ──────────────────────────────────────────────────
# Copie este arquivo para .streamlit/secrets.toml e preencha os valores.
# O arquivo secrets.toml está no .gitignore — nunca comite credenciais reais.
#
# Em produção (Railway, Render, Streamlit Cloud), configure as variáveis de
# ambiente diretamente no painel do serviço de hospedagem — não é necessário
# enviar o arquivo secrets.toml para o servidor.
#
# ─── Como gerar o hash bcrypt da senha ───────────────────────────────────────
# Execute no terminal (após instalar as dependências):
#
#   python -c "import bcrypt; print(bcrypt.hashpw(b'sua_senha_aqui', bcrypt.gensalt()).decode())"
#
# Cole o resultado (começa com $2b$12$...) no campo password_hash abaixo.
# ─────────────────────────────────────────────────────────────────────────────

# Usuário 1
[credentials.thiago]
name         = "Thiago Carvalho"
password_hash = "$2b$12$SUBSTITUA_PELO_HASH_GERADO_ACIMA"

# Adicione mais usuários conforme necessário:
# [credentials.outro_usuario]
# name         = "Nome Completo"
# password_hash = "$2b$12$..."
